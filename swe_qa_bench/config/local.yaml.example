# SWE-QA-Bench local config (copy to local.yaml).
# Keep this file minimal; defaults live in swe_qa_bench/config/default.yaml.

run:
  mode: tools  # bash | tools
  tools_prompt: neutral  # tools only: neutral | search_first | search_fallback
  method: ""  # optional; non-neutral tools_prompt auto-appends suffix
  output_dir: ""  # optional; leave empty to use default timestamped output

paths:
  # Required for any run:
  dataset_root: /abs/path/to/SWE-QA-Bench/datasets
  output_model_name: openai_deepseek-v3.2

  # Optional overrides (defaults are relative to repo):
  # repos_root: /abs/path/to/datasets/repos
  # indexes_root: /abs/path/to/swe_qa_bench/indexes
  # model_root: /abs/path/to/locbench/models/CodeRankEmbed
  # output_root: /abs/path/to/swe_qa_bench/results

model:
  # Optional: override default model selection
  model_class: chatanywhere
  model_name: deepseek-v3.2

env:
  # API keys / endpoints for your model provider
  OPENAI_API_KEY: sk-xxx
  OPENAI_API_BASE: https://api.example.com/v1/chat/completions
